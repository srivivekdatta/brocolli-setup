{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wire.payment.v1",
  "title": "WirePayment",
  "description": "Wire payment event schema — ISO 20022 aligned (pacs.008). v1.1.0",
  "type": "object",
  "required": ["transaction"],
  "additionalProperties": false,
  "properties": {
    "transaction": {
      "type": "object",
      "required": ["debitAccount", "creditAccount", "transactionData"],
      "additionalProperties": false,
      "properties": {
        "debitAccount": {
          "$ref": "#/definitions/account"
        },
        "creditAccount": {
          "$ref": "#/definitions/account"
        },
        "transactionData": {
          "type": "object",
          "required": [
            "transactionId",
            "amount",
            "currency",
            "valueDate",
            "paymentType"
          ],
          "additionalProperties": false,
          "properties": {
            "transactionId": {
              "type": "string",
              "format": "uuid",
              "description": "Unique transaction reference — UUID v4"
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Transaction amount — use BigDecimal on consumer side"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$",
              "description": "ISO 4217 currency code e.g. USD, EUR, GBP"
            },
            "valueDate": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 date-time — UTC preferred e.g. 2026-05-02T14:30:00Z"
            },
            "paymentType": {
              "type": "string",
              "enum": ["WIRE", "ACH", "FEDNOW", "CHIPS", "FPS"],
              "description": "Payment rail. WIRE=Fedwire, ACH=NACHA, FEDNOW=FedNow instant, CHIPS=Clearing House, FPS=UK Faster Payments"
            },
            "memo": {
              "type": "string",
              "maxLength": 140,
              "description": "Free-text remittance info — ISO 20022 max 140 chars"
            },
            "purposeCode": {
              "type": "string",
              "maxLength": 10,
              "description": "ISO 20022 Purpose2Choice code e.g. SALA, SUPP, TREA, INTC"
            }
          }
        }
      }
    },
    "party": {
      "type": "object",
      "description": "Originating party context — optional. Present when payment is initiated via online banking or API. Absent for bulk/file-based submissions.",
      "required": ["userId", "companyId"],
      "additionalProperties": false,
      "properties": {
        "userId": {
          "type": "string",
          "description": "Originating user identifier"
        },
        "companyId": {
          "type": "string",
          "description": "Originating company / legal entity identifier"
        }
      }
    }
  },
  "definitions": {
    "account": {
      "type": "object",
      "required": ["accountNumber", "routingNumber", "accountHolderName"],
      "additionalProperties": false,
      "properties": {
        "accountNumber": {
          "type": "string",
          "pattern": "^[0-9]{4,17}$",
          "description": "BBAN — 4 to 17 digits"
        },
        "routingNumber": {
          "type": "string",
          "pattern": "^[0-9]{9}$",
          "description": "ABA routing transit number — 9 digits"
        },
        "bankName": {
          "type": "string",
          "maxLength": 140,
          "description": "Financial institution name"
        },
        "bic": {
          "type": "string",
          "pattern": "^[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
          "description": "ISO 9362 BIC — 8 or 11 characters. Required for WIRE/CHIPS/FPS rails"
        },
        "accountHolderName": {
          "type": "string",
          "maxLength": 140,
          "description": "Legal name of account holder"
        },
        "address": {
          "$ref": "#/definitions/postalAddress"
        }
      }
    },
    "postalAddress": {
      "type": "object",
      "required": ["country"],
      "additionalProperties": false,
      "description": "ISO 20022 PostalAddress24 — hybrid structured + free-text fallback lines",
      "properties": {
        "addressType": {
          "type": "string",
          "enum": ["ADDR", "PBOX", "HOME", "BIZZ", "MLTO", "DLVY"],
          "description": "ISO 20022 AddressType2Code. ADDR=postal, BIZZ=business, PBOX=PO box"
        },
        "streetName": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 StrtNm"
        },
        "buildingNumber": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 BldgNb"
        },
        "buildingName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 BldgNm"
        },
        "floor": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 Flr"
        },
        "postBox": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 PstBx"
        },
        "room": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 Room"
        },
        "postCode": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 PstCd"
        },
        "townName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 TwnNm — required when structured fields are used"
        },
        "townLocationName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 TwnLctnNm — district or suburb"
        },
        "districtName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 DstrctNm"
        },
        "countrySubDivision": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 CtrySubDvsn — state, province, county"
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code e.g. US, GB, DE. Required — drives sanctions screening jurisdiction"
        },
        "addressLines": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70
          },
          "maxItems": 7,
          "description": "ISO 20022 AdrLine — fallback free-text lines. Use only when structured fields cannot represent the address"
        }
      }
    }
  }
}
