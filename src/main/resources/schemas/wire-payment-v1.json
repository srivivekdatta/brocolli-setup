{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wire.payment.v1",
  "title": "WirePayment",
  "description": "Wire payment event schema — ISO 20022 aligned (pacs.008). v1.3.0",
  "type": "object",
  "required": [
    "transaction"
  ],
  "additionalProperties": false,
  "properties": {
    "transaction": {
      "type": "object",
      "required": [
        "wireData"
      ],
      "additionalProperties": false,
      "properties": {
        "wireData": {
          "type": "object",
          "required": [
            "transactionId",
            "amount",
            "currency",
            "valueDate",
            "paymentType",
            "debit",
            "credit"
          ],
          "additionalProperties": false,
          "properties": {
            "transactionId": {
              "type": "string",
              "format": "uuid",
              "description": "Unique transaction reference — UUID v4"
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Instructed settlement amount — use BigDecimal on consumer side, never Double"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$",
              "description": "Instructed/settlement currency — ISO 4217 e.g. USD. May differ from debit/credit account currencies in FX wires"
            },
            "valueDate": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 settlement date-time — UTC preferred e.g. 2026-05-02T14:30:00Z"
            },
            "paymentType": {
              "type": "string",
              "enum": [
                "WIRE",
                "ACH",
                "FEDNOW",
                "CHIPS",
                "FPS"
              ],
              "description": "Payment rail. WIRE=Fedwire, ACH=NACHA, FEDNOW=FedNow instant, CHIPS=Clearing House, FPS=UK Faster Payments"
            },
            "memo": {
              "type": "string",
              "maxLength": 140,
              "description": "Free-text remittance info — ISO 20022 max 140 chars"
            },
            "purposeCode": {
              "type": "string",
              "maxLength": 10,
              "description": "ISO 20022 Purpose2Choice code e.g. SALA, SUPP, TREA, INTC"
            },
            "debit": {
              "$ref": "#/definitions/wireParty"
            },
            "credit": {
              "$ref": "#/definitions/wireParty"
            }
          }
        }
      }
    },
    "party": {
      "type": "object",
      "description": "Originating party context — optional. Present for online/API-initiated payments. Absent for bulk/file-based submissions.",
      "required": [
        "userId",
        "companyId"
      ],
      "additionalProperties": false,
      "properties": {
        "userId": {
          "type": "string",
          "description": "Originating user identifier"
        },
        "companyId": {
          "type": "string",
          "description": "Originating company / legal entity identifier"
        }
      }
    }
  },
  "definitions": {
    "wireParty": {
      "type": "object",
      "required": [
        "account"
      ],
      "additionalProperties": false,
      "description": "Debit or credit party — account + bank identity + currency + country + optional address",
      "properties": {
        "account": {
          "$ref": "#/definitions/account"
        },
        "address": {
          "$ref": "#/definitions/postalAddress"
        }
      }
    },
    "account": {
      "type": "object",
      "required": [
        "accountNumber",
        "accountHolderName",
        "currency",
        "countryCode",
        "bankId",
        "bankIdType"
      ],
      "additionalProperties": false,
      "properties": {
        "accountNumber": {
          "type": "string",
          "pattern": "^[0-9A-Za-z]{4,34}$",
          "description": "Account number — numeric for ABA/CHIPS, alphanumeric for IBAN-style or FPS"
        },
        "accountHolderName": {
          "type": "string",
          "maxLength": 140,
          "description": "Legal name of account holder — ISO 20022 max 140 chars"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Account currency — ISO 4217 e.g. USD, GBP, EUR. May differ from instructed currency in FX wires"
        },
        "countryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "Account domicile country — ISO 3166-1 alpha-2 e.g. US, GB, DE. Used for sanctions screening jurisdiction"
        },
        "bankId": {
          "type": "string",
          "maxLength": 35,
          "description": "Bank identifier value — format depends on bankIdType. ABA=9-digit routing, BIC=8 or 11 chars, CHIPS=4-digit UID, SORT=6-digit UK sort code"
        },
        "bankIdType": {
          "type": "string",
          "enum": [
            "ABA",
            "BIC",
            "CHIPS",
            "SORT"
          ],
          "description": "Bank identifier type. ABA=US routing number, BIC=ISO 9362 SWIFT code, CHIPS=Clearing House UID, SORT=UK sort code"
        },
        "bankName": {
          "type": "string",
          "maxLength": 140,
          "description": "Financial institution name — optional, informational"
        }
      }
    },
    "postalAddress": {
      "type": "object",
      "required": [
        "country"
      ],
      "additionalProperties": false,
      "description": "ISO 20022 PostalAddress24 — hybrid structured + free-text fallback lines",
      "properties": {
        "addressType": {
          "type": "string",
          "enum": [
            "ADDR",
            "PBOX",
            "HOME",
            "BIZZ",
            "MLTO",
            "DLVY"
          ],
          "description": "ISO 20022 AddressType2Code. ADDR=postal, BIZZ=business, PBOX=PO box"
        },
        "streetName": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 StrtNm"
        },
        "buildingNumber": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 BldgNb"
        },
        "buildingName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 BldgNm"
        },
        "floor": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 Flr"
        },
        "postBox": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 PstBx"
        },
        "room": {
          "type": "string",
          "maxLength": 70,
          "description": "ISO 20022 Room"
        },
        "postCode": {
          "type": "string",
          "maxLength": 16,
          "description": "ISO 20022 PstCd"
        },
        "townName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 TwnNm — required when structured fields are used"
        },
        "townLocationName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 TwnLctnNm — district or suburb"
        },
        "districtName": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 DstrctNm"
        },
        "countrySubDivision": {
          "type": "string",
          "maxLength": 35,
          "description": "ISO 20022 CtrySubDvsn — state, province, county"
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code e.g. US, GB, DE. Required — drives sanctions screening jurisdiction"
        },
        "addressLines": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70
          },
          "maxItems": 7,
          "description": "ISO 20022 AdrLine — fallback free-text lines. Use only when structured fields cannot represent the address"
        }
      }
    }
  }
}